{
    "php": {
        "version": "8.3",
        "extensions": [
            "pdo_mysql",
            "mbstring",
            "tokenizer",
            "xml",
            "ctype",
            "json",
            "bcmath",
            "curl",
            "gd",
            "fileinfo",
            "openssl"
        ]
    },
    "build": {
        "commands": {
            "install": [
                "composer install --no-interaction --optimize-autoloader --no-dev --ignore-platform-reqs"
            ],
            "postInstall": [
                "php artisan key:generate",
                "php artisan storage:link"
            ]
        }
    },
    "deploy": {
        "startCommand": "php artisan serve --host=0.0.0.0 --port=${PORT:-8000}"
    }
}