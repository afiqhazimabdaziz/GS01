{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "php artisan optimize",
    "nixPkgs": ["nodejs_22", "php82"]
  },
  "deploy": {
    "startCommand": "supervisord -c supervisord.conf",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}